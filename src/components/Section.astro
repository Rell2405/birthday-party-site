---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  class?: string;
}

const { id, eyebrow, title, subtitle, class: className = "" } = Astro.props;
---

<section id={id} class={`mx-auto max-w-6xl scroll-mt-20 px-4 py-16 sm:px-6 sm:py-24 ${className}`}>
  <div class="mx-auto max-w-2xl text-center">
    {
      eyebrow && (
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-gold-400">
          {eyebrow}
        </p>
      )
    }
    <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
      {title}
    </h2>
    {subtitle && <p class="mt-4 text-lg text-plum-300">{subtitle}</p>}
  </div>

  <div class="mt-12">
    <slot />
  </div>
</section>
