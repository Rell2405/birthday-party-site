---
import { party } from "../data/party";
import Countdown from "./react/Countdown.tsx";
---

<section
  id="top"
  class="relative overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Decorative gradient glows -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-plum-600/30 blur-3xl"
    >
    </div>
    <div
      class="absolute top-20 -right-24 h-96 w-96 rounded-full bg-gold-500/20 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-blush-300/10 blur-3xl"
    >
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-20 text-center sm:px-6 sm:py-28">
    <p
      class="animate-float-up mb-4 inline-flex items-center gap-2 rounded-full border border-gold-400/40 bg-gold-400/10 px-4 py-1.5 text-sm font-medium text-gold-300"
    >
      <span aria-hidden="true">✨</span>
      You're invited
    </p>

    <h1
      id="hero-heading"
      class="animate-float-up font-display text-5xl font-bold leading-[1.05] text-white sm:text-7xl"
      style="animation-delay: 0.05s"
    >
      {party.title}
    </h1>

    <p
      class="animate-float-up mx-auto mt-6 max-w-2xl text-lg text-plum-200 sm:text-xl"
      style="animation-delay: 0.1s"
    >
      {party.tagline}
    </p>

    <div
      class="animate-float-up mt-8 flex flex-col items-center gap-2 text-plum-100"
      style="animation-delay: 0.15s"
    >
      <p class="text-lg font-semibold">{party.date}</p>
      <p class="text-plum-300">{party.time} · {party.venue.name}</p>
    </div>

    <div
      class="animate-float-up mt-10 flex justify-center"
      style="animation-delay: 0.2s"
    >
      <Countdown client:load target={party.startsAt} />
    </div>

    <div
      class="animate-float-up mt-10 flex flex-wrap justify-center gap-3"
      style="animation-delay: 0.25s"
    >
      <a
        href="#rsvp"
        class="rounded-full bg-gold-400 px-7 py-3 text-base font-semibold text-plum-950 shadow-lg transition hover:bg-gold-300 hover:shadow-gold-400/30"
      >
        RSVP now
      </a>
      <a
        href="#playlist"
        class="rounded-full border border-plum-600 px-7 py-3 text-base font-semibold text-plum-100 transition hover:border-gold-400 hover:text-white"
      >
        Add a song 🎵
      </a>
    </div>
  </div>
</section>
